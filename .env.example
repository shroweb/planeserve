# ─── Database ────────────────────────────────────────────────────────────────
# Runtime connection. Locally: direct Postgres. In production (serverless):
# use the POOLED endpoint (Neon "-pooler" / Supabase port 6543 / PgBouncer).
DATABASE_URL=postgres://planeserve:planeserve@localhost:54329/planeserve

# Direct (non-pooled) connection — used ONLY for migrations / DDL (db:deploy,
# drizzle-kit, scripts/auth-schema.ts). Leave unset locally; in production set
# this to the direct Neon/Supabase endpoint. Falls back to DATABASE_URL.
# DIRECT_URL=

# Per-instance pool size. Auto-set to 1 on Vercel, 10 elsewhere. Override here.
# DB_POOL_MAX=

# ─── Auth (better-auth) ──────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string   # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000                     # prod: https://your-domain

# ─── Nitro / server ──────────────────────────────────────────────────────────
# node-server = Railway/Render/VPS · vercel = Vercel · cloudflare = CF Workers
# (cloudflare will NOT work with the pg driver as-is — needs Hyperdrive/Neon HTTP)
NITRO_PRESET=node-server
PORT=3000

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                       # sk_live_… (or sk_test_…)
STRIPE_WEBHOOK_SECRET=                    # whsec_… (once a webhook endpoint exists)
VITE_STRIPE_PUBLISHABLE_KEY=              # pk_live_… — exposed to the client (build-time)

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=                           # leave blank to log emails to console
RESEND_FROM=Aircraft Program <ops@planeserve.aero>   # must be a verified Resend domain
